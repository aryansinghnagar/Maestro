{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GestureControllerConfig",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "camera": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "device_id": { "type": "integer", "minimum": -1 },
        "frame_width": { "type": "integer", "minimum": 1 },
        "frame_height": { "type": "integer", "minimum": 1 },
        "fps_target": { "type": "integer", "minimum": 1, "maximum": 240 },
        "backend_preference": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reconnect_backoff_ms": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 }
        },
        "watchdog_timeout_ms": { "type": "integer", "minimum": 1 }
      },
      "required": ["device_id", "frame_width", "frame_height", "fps_target"]
    },
    "filtering": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["one_euro", "none"] },
        "one_euro": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min_cutoff": { "type": "number", "minimum": 0.001 },
            "beta": { "type": "number", "minimum": 0.0 },
            "derivative_cutoff": { "type": "number", "minimum": 0.001 }
          }
        },
        "dynamic_adaptation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "lighting_enabled": { "type": "boolean" },
            "depth_scaling_enabled": { "type": "boolean" }
          }
        },
        "tremor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "min_freq": { "type": "number" },
            "max_freq": { "type": "number" },
            "history_length": { "type": "integer" }
          }
        }
      }
    },
    "sensitivity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "global_multiplier": { "type": "number", "minimum": 0.01, "maximum": 100.0 }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_hands": { "type": "integer", "minimum": 1, "maximum": 10 },
        "min_detection_confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "min_tracking_confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "inference_backend": { "type": "string" },
        "quantization": { "type": "string" },
        "skip_model_verification": { "type": "boolean" }
      }
    },
    "hud": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "opacity": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "show_tracking_points": { "type": "boolean" },
        "show_progress_ring": { "type": "boolean" },
        "confirmation_duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": { "type": "string", "enum": ["debug", "info", "warning", "error", "critical", "DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"] },
        "structured": { "type": "boolean" },
        "rotation": { "type": "string" },
        "max_files": { "type": "integer", "minimum": 1 }
      }
    },
    "a11y": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "high_contrast": { "type": "boolean" },
        "reduced_motion": { "type": "boolean" },
        "dwell_click_enabled": { "type": "boolean" },
        "dwell_duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "engine": { "type": "string" },
        "model_path": { "type": "string" },
        "wake_word": { "type": "string" }
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "endpoint": { "type": "string" }
      }
    },
    "i18n": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "locale": { "type": "string" },
        "fallback": { "type": "string" }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auto_detect_app": { "type": "boolean" },
        "devices": {
          "type": "array"
        }
      }
    },
    "triggers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditions": {
          "type": "array"
        }
      }
    }
  }
}
