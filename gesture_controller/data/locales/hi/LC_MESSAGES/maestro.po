msgstr "डाउनलोड सफल"

msgid "Vosk speech model downloaded and set up successfully!"
msgstr "Vosk स्पीच मॉडल सफलतापूर्वक डाउनलोड और सेटअप हो गया!"

msgid "Download Failed"
msgstr "डाउनलोड विफल"
